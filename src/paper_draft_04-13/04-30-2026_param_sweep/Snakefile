#Targets are outputs and dependencies are inputs
rule all:
    input:
     expanded_dir_pattern_gen,
     expanded_dir_pattern_loc,
     expanded_dir_pattern_ihh,
     expanded_dir_pattern_pi

#This rule creates the directories and slim scripts for each simulation
rule set_up_dirs:
    input:
        SLIM_SCRIPT_TEMPLATE
    output: 
     wrap_dir + DIR_NAME + "origins_{num_origins}_min_{min_num_origins}_rep_{rep}_mu_{mu}_sel_{selection_coeff}_rho_{rho}/sim_origins_{num_origins}_min_{min_num_origins}_rep_{rep}_mu_{mu}_sel_{selection_coeff}_rho_{rho}.slim"
    params:
        in_sim_template = SLIM_SCRIPT_TEMPLATE,
        out_sim_dir = wrap_dir + DIR_NAME + "origins_{num_origins}_min_{min_num_origins}_rep_{rep}_mu_{mu}_sel_{selection_coeff}_rho_{rho}/",
        NE = NE
    script:
        SLIM_SCRIPT_FILE

#This rule runs the slim script for each simulation
rule run_slim:
    input:
     wrap_dir + DIR_NAME + "origins_{num_origins}_min_{min_num_origins}_rep_{rep}_mu_{mu}_sel_{selection_coeff}_rho_{rho}/sim_origins_{num_origins}_min_{min_num_origins}_rep_{rep}_mu_{mu}_sel_{selection_coeff}_rho_{rho}.slim"

    output:
     wrap_dir + DIR_NAME + "origins_{num_origins}_min_{min_num_origins}_rep_{rep}_mu_{mu}_sel_{selection_coeff}_rho_{rho}/slim_output.txt"

    shell: "slim " + wrap_dir + DIR_NAME + "origins_{wildcards.num_origins}_min_{wildcards.min_num_origins}_rep_{wildcards.rep}_mu_{wildcards.mu}_sel_{wildcards.selection_coeff}_rho_{wildcards.rho}/sim_origins_{wildcards.num_origins}_min_{wildcards.min_num_origins}_rep_{wildcards.rep}_mu_{wildcards.mu}_sel_{wildcards.selection_coeff}_rho_{wildcards.rho}.slim > " + \
            wrap_dir + DIR_NAME + "origins_{wildcards.num_origins}_min_{wildcards.min_num_origins}_rep_{wildcards.rep}_mu_{wildcards.mu}_sel_{wildcards.selection_coeff}_rho_{wildcards.rho}/slim_output.txt 2> " + \
            wrap_dir + DIR_NAME + "origins_{wildcards.num_origins}_min_{wildcards.min_num_origins}_rep_{wildcards.rep}_mu_{wildcards.mu}_sel_{wildcards.selection_coeff}_rho_{wildcards.rho}/slim_error.txt"

#This rule parses and makes dataframes of the slim output
rule format_slim_output:
    input: 
     wrap_dir + DIR_NAME + "origins_{num_origins}_min_{min_num_origins}_rep_{rep}_mu_{mu}_sel_{selection_coeff}_rho_{rho}/slim_output.txt"

    output:
     wrap_dir + DIR_NAME + "origins_{num_origins}_min_{min_num_origins}_rep_{rep}_mu_{mu}_sel_{selection_coeff}_rho_{rho}/analysis/FilteredGenotypes",
     wrap_dir + DIR_NAME + "origins_{num_origins}_min_{min_num_origins}_rep_{rep}_mu_{mu}_sel_{selection_coeff}_rho_{rho}/analysis/FilteredLoci"
    params:
        out_sim_dir = wrap_dir + DIR_NAME + "origins_{num_origins}_min_{min_num_origins}_rep_{rep}_mu_{mu}_sel_{selection_coeff}_rho_{rho}/",
        hxb2_file = hxb2_file


    script:
        python_script_dir + "format_slim_output.py"

#This rule calculates nucleotide diversity 
rule calc_pi_div:
    input:
        wrap_dir + DIR_NAME + "origins_{num_origins}_min_{min_num_origins}_rep_{rep}_mu_{mu}_sel_{selection_coeff}_rho_{rho}/analysis/FilteredGenotypes"
    output: 
        wrap_dir + DIR_NAME + "origins_{num_origins}_min_{min_num_origins}_rep_{rep}_mu_{mu}_sel_{selection_coeff}_rho_{rho}/origins_{num_origins}_min_{min_num_origins}_rep_{rep}_pi.csv"
    params:
        window_size = WINDOW_SIZE,
        window_step = WINDOW_STEP,
        hxb2_file = hxb2_file,
        num_origins = "{num_origins}",
        min_num_origins = "{min_num_origins}",
        rep = "{rep}",
        mu = "{mu}",
        selection_coeff = "{selection_coeff}",
        rho = "{rho}"
    script:
        python_script_dir + "pi_diversity_sim.py"

#This rule calculates the EHH linkage statistic
rule calc_linkage_ihh:
    input:
        wrap_dir + DIR_NAME + "origins_{num_origins}_min_{min_num_origins}_rep_{rep}_mu_{mu}_sel_{selection_coeff}_rho_{rho}/analysis/FilteredGenotypes",
        wrap_dir + DIR_NAME + "origins_{num_origins}_min_{min_num_origins}_rep_{rep}_mu_{mu}_sel_{selection_coeff}_rho_{rho}/analysis/FilteredLoci"
    output:
        wrap_dir + DIR_NAME + "origins_{num_origins}_min_{min_num_origins}_rep_{rep}_mu_{mu}_sel_{selection_coeff}_rho_{rho}/origins_{num_origins}_min_{min_num_origins}_rep_{rep}_ihh_results.csv"
    params:
        hxb2_file = hxb2_file,
        #Set allele frequency threshold to 0 for IHH calculations since we will filter based on core allele frequency
        allele_freq_thresh = 0,
        core_freq_thresh = IHH_CORE_FREQ_THRESH
    script:
        python_script_dir + "ihh_sim.py"
