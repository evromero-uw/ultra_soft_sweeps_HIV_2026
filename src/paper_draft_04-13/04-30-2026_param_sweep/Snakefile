#The constants we will use for each run
DIR_NAME = '04-30-2026_sims/'
SLIM_SCRIPT_FILE = '04-30-2026_make_scripts.py'
SLIM_SCRIPT_TEMPLATE = '04-30-2026_sims.txt'
reps = range(5) #number of replicates
WINDOW_SIZE = 60
WINDOW_STEP = 20
IHH_CORE_FREQ_THRESH = 0.1
NE = 10000

#The population parameters we will sweep over
# mu = [10**(-7), 10**(-6), 10**(-5), 10**(-4)]
# mu = [10**(-7), 10**(-6), 10**(-5)]
mu = [10**(-6), 5*10**(-7), 10**(-7)]

selection_coeff = [0.1, 1, 5]

rho = [10**(-7), 10**(-6), 10**(-5)]


#Make a dictionary with the minimum number of origins for each number of origins
num_origins_list = [1, 2, 10, 20, 30, 50, 100]
min_num_origins_list = [1, 2, 5, 10, 20, 40, 80]
min_origins_dict = dict(zip(num_origins_list, min_num_origins_list))

# The patterns for the genotype and loci dataframes
# We want specific combinations of num_origins and min_num_origins
full_dir_pattern_gen = []
full_dir_pattern_loc = []
full_dir_pattern_pi = []
full_dir_pattern_ihh = []

for num_origins in num_origins_list:
    min_num_origins = min_origins_dict[num_origins]
    for rep in reps:
        full_dir_pattern_gen.append(wrap_dir + DIR_NAME + f"origins_{num_origins}_min_{min_num_origins}_rep_{rep}_mu_{{mu}}_sel_{{selection_coeff}}_rho_{{rho}}/analysis/FilteredGenotypes")
        full_dir_pattern_loc.append(wrap_dir + DIR_NAME + f"origins_{num_origins}_min_{min_num_origins}_rep_{rep}_mu_{{mu}}_sel_{{selection_coeff}}_rho_{{rho}}/analysis/FilteredLoci")
        full_dir_pattern_pi.append(wrap_dir + DIR_NAME + f"origins_{num_origins}_min_{min_num_origins}_rep_{rep}_mu_{{mu}}_sel_{{selection_coeff}}_rho_{{rho}}/origins_{num_origins}_min_{min_num_origins}_rep_{rep}_pi.csv")
        full_dir_pattern_ihh.append(wrap_dir + DIR_NAME + f"origins_{num_origins}_min_{min_num_origins}_rep_{rep}_mu_{{mu}}_sel_{{selection_coeff}}_rho_{{rho}}/origins_{num_origins}_min_{min_num_origins}_rep_{rep}_ihh_results.csv")

# Now we want to expand the patterns for the combinations of mu, selection_coeff, and rho
expanded_dir_pattern_gen = []
expanded_dir_pattern_loc = []
expanded_dir_pattern_pi = []
expanded_dir_pattern_ihh = []
for i in range(len(num_origins_list) * len(reps)):
    expanded_dir_pattern_gen.extend(expand(full_dir_pattern_gen[i],
        mu = mu,
        selection_coeff = selection_coeff,
        rho = rho))
    expanded_dir_pattern_loc.extend(expand(full_dir_pattern_loc[i],
        mu = mu,
        selection_coeff = selection_coeff,
        rho = rho))
    expanded_dir_pattern_pi.extend(expand(full_dir_pattern_pi[i],
        mu = mu,
        selection_coeff = selection_coeff,
        rho = rho))
    expanded_dir_pattern_ihh.extend(expand(full_dir_pattern_ihh[i],
        mu = mu,
        selection_coeff = selection_coeff,
        rho = rho))

